DATABASE_URL="postgresql://cardcodex:cardcodex123@localhost:5432/cardcodex?schema=public"

# Canonical public URL, used for sitemap.xml, robots.txt, and absolute
# Open Graph/canonical URLs in metadata. No trailing slash.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Only used by `docker-compose.prod.yml` (docker:prod:up). Not read for local
# dev — docker-compose.yml's Postgres container is throwaway, so the
# cardcodex/cardcodex123 default above is fine there. For an actual
# deployment, set a real password here before running docker:prod:up; the
# compose file refuses to start without it.
# POSTGRES_USER="cardcodex"
# POSTGRES_PASSWORD="change-me-to-a-strong-random-value"
# POSTGRES_DB="cardcodex"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A Yu-Gi-Oh! trading card with multilingual data.
model Card {
  id            String   @id @default(cuid())
  ygoprodeckId  Int      @unique
  slug          String   @unique
  nameEn        String
  namePt        String?
  nameJa        String?
  descEn        String   @db.Text
  descPt        String?  @db.Text
  descJa        String?  @db.Text
  type          String          // e.g. "Effect Monster", "Spell Card"
  frameType     String?         // canonical subtype for filtering, e.g. "effect", "effect_pendulum", "spell"
  race          String          // monster race (e.g. "Dragon") or spell/trap subtype (e.g. "Field", "Counter")
  attribute     String?         // e.g. "LIGHT", "DARK"
  atk           Int?
  def           Int?
  level         Int?
  archetype     String?
  rarity        String   @default("Common") // e.g. "Ultra Rare", "Secret Rare"
  imageUrl      String
  imageSmallUrl String?
  cardSetCode   String?
  releaseDate   DateTime?
  banTcg        String?         // "Forbidden" | "Limited" | "Semi-Limited", null if unrestricted
  banOcg        String?
  lastSyncedAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rulings       Ruling[]
  deckUsages    DeckUsage[]
  animeDeckCards AnimeDeckCard[]
  userDeckCards UserDeckCard[]

  @@index([archetype])
  @@index([type])
  @@index([rarity])
  @@index([frameType])
  @@index([banTcg])
  @@index([banOcg])
}

/// A ruling or clarification for a specific card.
model Ruling {
  id     String @id @default(cuid())
  cardId String
  index  Int
  textEn String @db.Text
  textPt String? @db.Text
  source String @default("community") // "community" | "ygorganization" | "official"

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, index])
}

/// Aggregation of deck inclusion data for a card.
model DeckUsage {
  id               String @id @default(cuid())
  cardId           String
  deckName         String
  copies           Int    @default(3)
  inclusionPercent Float  // 0-100

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, deckName])
}

/// A curated decklist used by an anime character during a specific season/arc.
/// Hand-curated editorial content — there's no API source for this, unlike Card.
model AnimeDeck {
  id            String   @id @default(cuid())
  slug          String   @unique
  character     String                          // e.g. "Yugi Muto"
  series        String   @default("Yu-Gi-Oh! Duel Monsters")
  season        String                          // e.g. "Season 1: Duelist Kingdom"
  titleEn       String
  titlePt       String?
  titleJa       String?
  descriptionEn String   @db.Text
  descriptionPt String?  @db.Text
  descriptionJa String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cards AnimeDeckCard[]

  @@index([character])
}

/// A single card entry within an anime deck.
model AnimeDeckCard {
  id       String @id @default(cuid())
  deckId   String
  cardId   String
  category String @default("Main") // "Main" | "Extra" (Fusion/Synchro/etc.)
  copies   Int    @default(1)

  deck AnimeDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([deckId, cardId])
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) + Prisma adapter — standard schema shape.
// See src/lib/auth.ts. Google is the only provider for now; credentials are
// placeholders in .env until real ones are configured (see README).
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]
  decks    UserDeck[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Legality mode for a user-built deck — governs which copy-count rules apply.
enum DeckFormat {
  FREE
  TCG
  OCG
}

/// A deck a signed-in user built themselves (distinct from the curated AnimeDeck).
/// Shareable via its slug: anyone with the link can view; only the owner can edit.
model UserDeck {
  id        String     @id @default(cuid())
  slug      String     @unique
  userId    String
  name      String
  format    DeckFormat @default(FREE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards UserDeckCard[]

  @@index([userId])
}

/// A card entry within a user deck. `category` is derived automatically from
/// the card's frameType (Fusion/Synchro/XYZ/Link → "Extra", else "Main").
model UserDeckCard {
  id       String @id @default(cuid())
  deckId   String
  cardId   String
  category String @default("Main") // "Main" | "Extra"
  copies   Int    @default(1)

  deck UserDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([deckId, cardId])
}
